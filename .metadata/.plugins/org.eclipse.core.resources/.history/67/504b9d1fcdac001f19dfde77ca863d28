package com.example.book.repository;

import org.springframework.data.jpa.repository.Modifying;
import org.springframework.data.jpa.repository.Query;
import org.springframework.data.repository.query.Param;
import org.springframework.stereotype.Repository;
import org.springframework.transaction.annotation.Transactional;

import com.example.book.base.BaseRepository;
import com.example.book.entity.Auther;

@Repository
public interface AutherRrepo extends BaseRepository<Auther, Long> {

	
	
	 	@Modifying
	    @Transactional
	    @Query("UPDATE Auther a SET a.statuscode = :statuscode WHERE a.id = :id")
	    void updateStatus(Long id, String statuscode);
	
}
