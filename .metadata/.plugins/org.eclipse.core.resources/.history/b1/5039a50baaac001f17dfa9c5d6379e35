package com.example.book.repository;

import java.util.List;
import java.util.Optional;

import org.springframework.data.jpa.repository.EntityGraph;
import org.springframework.data.jpa.repository.JpaRepository;
import org.springframework.data.jpa.repository.Query;
import org.springframework.stereotype.Repository;

import com.example.book.entity.Auther;
import com.example.book.entity.Book;

@Repository
public interface BookRrepo extends JpaRepository<Book, Long> {

	@Override
	@EntityGraph(attributePaths = {"auther"})
	Optional<Book> findById(Long id) ;
	
	/*
	@Query("select book from Book book where id = :id")
	Optional<Book> findByIdCustom(Long id) ;
	*/
	
	@Override
	@EntityGraph(attributePaths = {"auther"})
	List<Book> findAll();
	
	@Query("delete from Book where book.author.id = :id")
	int deleteByAutherId(Long id);
	
}
