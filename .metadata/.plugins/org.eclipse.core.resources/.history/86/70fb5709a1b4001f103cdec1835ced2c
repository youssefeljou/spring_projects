		books.add(book);
	}

	// Method to remove a book from the author's list of books
	public void removeBook(Book book) {
		books.remove(book);
	}

	public List<Book> getBooks() {
		return books;
	}

	public void setBooks(List<Book> books) {
		this.books = books;
	}
	*/
}
