package com.example.book.repository;

import jakarta.persistence.Entity;
import jakarta.transaction.Transactional;
import org.springframework.data.jpa.repository.EntityGraph;
import org.springframework.data.jpa.repository.Modifying;
import org.springframework.data.jpa.repository.Query;
import org.springframework.stereotype.Repository;
import com.example.book.base.BaseRepository;
import com.example.book.entity.Book;

import java.util.List;
import java.util.Optional;

@Repository
public interface BookRepository extends BaseRepository<Book, Long> {


    @EntityGraph(attributePaths = {"author"})
    Optional<Book> findById(long id);

    @Override
    @EntityGraph(attributePaths = {"author"})
    List<Book> findAll();

    @EntityGraph(attributePaths = {"author"})
    @Query("select book from Book  book join book.author author where"
            +"(:name is null or book.name like :name)"
            +"and (:price is null book.price >= :price)"
            +"and (:authorId is null or author.id= authorId)")
    List<Book> filter(String name,double price,long authorId);

    @Transactional
    @Modifying
    @Query("delete from Book where author.id =:id")
    int deleteByAuthorId (long id);

    @Transactional
    @Modifying
    @Query("UPDATE Book b SET b.status = 'restored' WHERE b.author.id = :authorId")
    void restoreByAuthorId(@Param("authorId") long authorId);




}
