package com.example.book.controller;

import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.http.ResponseEntity;
import org.springframework.validation.annotation.Validated;
import org.springframework.web.bind.annotation.DeleteMapping;
import org.springframework.web.bind.annotation.GetMapping;
import org.springframework.web.bind.annotation.PathVariable;
import org.springframework.web.bind.annotation.PostMapping;
import org.springframework.web.bind.annotation.PutMapping;
import org.springframework.web.bind.annotation.RequestBody;
import org.springframework.web.bind.annotation.RequestMapping;
import org.springframework.web.bind.annotation.RestController;

import com.example.book.dto.AutherDto;
import com.example.book.entity.Auther;
import com.example.book.entity.AutherSearch;
import com.example.book.service.AutherService;

import io.swagger.v3.oas.annotations.Operation;
import jakarta.validation.Valid;
import jakarta.validation.constraints.Max;
import jakarta.validation.constraints.Min;

@Validated
@RestController
@RequestMapping("/auther")
public class AutherController {

    // Service to handle author-related operations
    private AutherService autherService;

    // Constructor injection of the autherService
    @Autowired
    public AutherController(AutherService autherService) {
        super();
        this.autherService = autherService;
    }

    // Endpoint to get an author by ID with validation
    @Operation(summary = "get author by using id")
    @GetMapping("/{id}")
    public ResponseEntity<?> findById(@Min(value = 1) @Max(value = 2000) @PathVariable long id) {
        // Fetch author by ID and return in the response
        return ResponseEntity.ok(autherService.findById(id));
    }

    // Endpoint to get all authors
    @Operation(summary = "get authors")
    @GetMapping("/findall")
    public ResponseEntity<?> findAll() {
        // Fetch all authors and return in the response
        return ResponseEntity.ok(autherService.findAll());
    }

    // Endpoint to search for authors based on criteria in the request body
    @Operation(summary = "get authors that matches request body parameters")
    @PostMapping("/spec")
    public ResponseEntity<?> findByAutherSpec(@RequestBody AutherSearch autherSearch) {
        // Search authors based on the criteria provided in AutherSearch
        return ResponseEntity.ok(autherService.findByAutherSpec(autherSearch));
    }

    // Endpoint to insert a new author with validation
    @Operation(summary = "insert author with request body parameters")
    @PostMapping("")
    public ResponseEntity<?> insert(@RequestBody @Valid AutherDto dto) {
        // Convert AutherDto to Auther entity
        Auther entity = new Auther();
        entity.setName(dto.getName());
        entity.setIpAddress(dto.getIpAddress());
        entity.setEmail(dto.getEmail());
        // Insert the new author and return the response
        return ResponseEntity.ok(autherService.insert(entity));
    }

    // Endpoint to update an existing author with validation
    @Operation(summary = "update author using its id with request body parameters")
    @PutMapping("")
    public ResponseEntity<?> update(@RequestBody @Valid Auther entity) {
        // Update the author and return the response
        return ResponseEntity.ok(autherService.update(entity));
    }

    // Endpoint to update the status of an author using its ID and new status in the request body
    @Operation(summary = "update status of author using its id and new status in request body")
    @PutMapping("/status/{id}")
    public ResponseEntity<?> updateStatus(@PathVariable("id") Long id, @RequestBody String status) {
        try {
            // Update the author's status and return success message
            autherService.updateStatusById(id, status);
            return ResponseEntity.ok("Status updated successfully");
        } catch (RuntimeException e) {
            // Handle any errors and return error message
            return ResponseEntity.status(500).body("Error: " + e.getMessage());
        }
    }

    // Endpoint to delete an author by ID
    @Operation(summary = "delete author by using its id")
    @DeleteMapping("/{id}")
    public ResponseEntity<?> deleteById(@PathVariable long id) {
        // Delete the author and return the response
        autherService.deleteById(id);
        return ResponseEntity.ok(null);
    }
}
