package com.example.book.controller;

import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.http.ResponseEntity;
import org.springframework.web.bind.annotation.DeleteMapping;
import org.springframework.web.bind.annotation.GetMapping;
import org.springframework.web.bind.annotation.PathVariable;
import org.springframework.web.bind.annotation.PostMapping;
import org.springframework.web.bind.annotation.PutMapping;
import org.springframework.web.bind.annotation.RequestBody;
import org.springframework.web.bind.annotation.RequestMapping;
import org.springframework.web.bind.annotation.RestController;

import com.example.book.dto.BookDto;
import com.example.book.entity.Book;
import com.example.book.service.BookService;

import io.swagger.v3.oas.annotations.Operation;
import jakarta.validation.Valid;

@RestController
@RequestMapping("/book")
public class BookController {

    // Service to handle book-related operations
    private BookService bookService;

    // Constructor injection of the bookService
    @Autowired
    public BookController(BookService bookService) {
        super();
        this.bookService = bookService;
    }

    // Endpoint to get a book by ID
    @Operation(summary = "Get book by ID")
    @GetMapping("/{id}")
    public ResponseEntity<?> findById(@PathVariable long id) {
        // Fetch book by ID and return in the response
        Book book = bookService.findById(id);
        /*
        BookDto dto= new BookDto();
        dto.setId(book.getId());
        dto.setName(book.getName());
        dto.setPrice(book.getPrice());
        dto.setAuther(book.getAuther());
        */
        return ResponseEntity.ok(bookService.findById(id));
    }

    // Endpoint to get all books
    @Operation(summary = "Get all books")
    @GetMapping("/findall")
    public ResponseEntity<?> findAll() {
        // Fetch all books and return in the response
        return ResponseEntity.ok(bookService.findAll());
    }

    // Endpoint to insert a new book with validation
    @Operation(summary = "Insert a new book")
    @PostMapping("")
    public ResponseEntity<?> insert(@RequestBody @Valid BookDto dto) {
        // Convert BookDto to Book entity
        Book book = new Book();
        book.setName(dto.getName());
        book.setPrice(dto.getPrice());
        book.setAuther(dto.getAuther());
        // Insert the new book and return the response
        return ResponseEntity.ok(bookService.insert(book));
    }

    // Endpoint to update an existing book with validation
    @Operation(summary = "Update an existing book")
    @PutMapping("")
    public ResponseEntity<?> update(@RequestBody @Valid Book entity) {
        // Update the book and return the response
        return ResponseEntity.ok(bookService.update(entity));
    }

    // Endpoint to update the status of a book using its ID and new status in the request body
    @Operation(summary = "Update book status by ID")
    @PutMapping("/status/{id}")
    public ResponseEntity<?> updateStatus(@PathVariable("id") Long id, @RequestBody String status) {
        try {
            // Update the book's status and return success message
            bookService.updateStatusById(id, status);
            return ResponseEntity.ok("Status updated successfully");
        } catch (RuntimeException e) {
            // Handle any errors and return error message
            return ResponseEntity.status(500).body("Error: " + e.getMessage());
        }
    }

    // Endpoint to delete a book by ID
    @Operation(summary = "Delete book by ID")
    @DeleteMapping("/{id}")
    public ResponseEntity<?> deleteById(@PathVariable long id) {
        // Delete the book and return the response
        bookService.deleteById(id);
        return ResponseEntity.ok(null);
    }

    // Endpoint to delete books by author ID
    @Operation(summary = "Delete books by author ID")
    @DeleteMapping("/auther/{id}")
    public ResponseEntity<?> deleteByAutherId(@PathVariable Long id) {
        // Delete books by author ID and return the response
        return ResponseEntity.ok(bookService.deleteByAutherId(id));
    }
}
