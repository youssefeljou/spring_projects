package com.example.book.entity;

import java.io.Serializable;
import java.util.ArrayList;
import java.util.List;

import org.hibernate.annotations.Formula;

import com.example.book.base.BaseEntity;
import com.example.book.validator.IpAddress;
import com.fasterxml.jackson.annotation.JsonManagedReference;

import jakarta.persistence.Entity;
import jakarta.persistence.OneToMany;
import jakarta.persistence.Table;
import jakarta.validation.constraints.Email;
import lombok.AllArgsConstructor;
import lombok.Getter;
import lombok.NoArgsConstructor;
import lombok.Setter;
import lombok.ToString;

/**
 * Entity class representing an Author (Auther). This class contains information
 * about the author, including the number of books written, the author's email,
 * IP address, and a list of books.
 */
@Entity
@Table(name = "authers")
@Setter
@Getter
@NoArgsConstructor
@AllArgsConstructor
//@Data can replace all notaions of lomboc and implement them all
public class Auther extends BaseEntity<Long> //implements Serializable
{

	// Formula to calculate the count of books written by the author
	@Formula("(select count(*) from books book where book.auther_id = id)")
	private long bookCount;

	// The author's IP address, validated using the custom IpAddress annotation
	@IpAddress
	private String ipAddress;

	// The author's email, validated with the @Email annotation
	@Email(message = "{validation.constraints.email.message}")
	private String email;

	// List of books written by the author, mapped by the 'auther' field in Book
	// entity
	@JsonManagedReference
	@OneToMany(mappedBy = "auther")
	private List<Book> books = new ArrayList<>();

	// Path to the author's image
	private String imagePath;

