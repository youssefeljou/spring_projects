package com.example.book.entity;

import jakarta.persistence.Entity;
import jakarta.persistence.Table;



@Entity
@Table(name = "authers")
public class Auther {

	
	private long id;
	
	private String name;

	public long getId() {
		return id;
	}

	public void setId(long id) {
		this.id = id;
	}

	public String getName() {
		return name;
	}

	public void setName(String name) {
		this.name = name;
	}
	
	
}
