package com.example.book.dto;

import com.example.book.entity.Auther;
import com.fasterxml.jackson.annotation.JsonBackReference;

import jakarta.validation.constraints.Max;
import jakarta.validation.constraints.Min;
import jakarta.validation.constraints.NotBlank;
import jakarta.validation.constraints.NotNull;

/**
 * Data Transfer Object (DTO) for the Book entity. This class is used to
 * transfer book data, typically between the API and service layers. It
 * represents a book with its price, name, and associated author.
 */
public class BookDto {

	// Unique identifier for the book
	private long id;

	// Name of the book, validated to ensure it's not blank
	@NotBlank
	private String name;

	// Price of the book, validated to be between 5 and 50000
	@Min(value = 5)
	@Max(value = 50000)
	private double price;

	// The author of the book, must not be null
	@NotNull
	private Auther auther;

	// Getter and setter methods for the fields

	public long getId() {
		return id;
	}

	public void setId(long id) {
		this.id = id;
	}

	public String getName() {
		return name;
	}

	public void setName(String name) {
		this.name = name;
	}

	public double getPrice() {
		return price;
	}

	public void setPrice(double price) {
		this.price = price;
	}

	public Auther getAuther() {
		return auther;
	}

	public void setAuther(Auther auther) {
		this.auther = auther;
	}
}
